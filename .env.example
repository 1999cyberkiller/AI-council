# 复制为 .env，并只填写需要接入的 provider。
# 未配置 key 时，应用会自动进入演示模式。

PORT=4177
HOST=127.0.0.1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.1-flash-lite-preview

XAI_API_KEY=
XAI_MODEL=grok-4-fast-non-reasoning

NVIDIA_API_KEY=
NVIDIA_CHAIR_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
MINIMAX_MODEL=minimaxai/minimax-m2.7

# 可选：任意 OpenAI-compatible 模型网关。
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_MODEL=

# 数据工具默认使用免费源。
# free：Yahoo Finance chart endpoint、Stooq CSV、SEC、DuckDuckGo HTML。
# paid：有 key 时优先 Alpaca、Brave、Tavily。
DATA_MODE=free

# 可选：付费或需 key 的实时行情源。仅 DATA_MODE=paid 时优先使用。
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# 可选：SEC 要求 User-Agent 包含联系信息。建议改成自己的邮箱或域名。
SEC_USER_AGENT=AI-Finance-Council contact@example.com

# 可选：付费或需 key 的 Web research。仅 DATA_MODE=paid 时优先使用。
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
